# ==============================
# SERVER CONFIG
# ==============================
PORT=5000
NODE_ENV=development

# ==============================
# DATABASE (Optional - MongoDB)
# Local: mongodb://127.0.0.1:27017/ai-caption-generator
# Atlas Free Tier: mongodb+srv://<user>:<pass>@cluster.mongodb.net/ai-caption-generator
# ==============================
MONGO_URI=mongodb://127.0.0.1:27017/ai-caption-generator

# ==============================
# FRONTEND URL (CORS ke liye)
# ==============================
CLIENT_URL=http://localhost:5173

# ==============================
# FILE UPLOAD LIMITS
# ==============================
MAX_FILE_SIZE_MB=500

# ==============================
# WHISPER (Speech-to-Text) CONFIG
# Local Python whisper environment ka path
# Model options: tiny, base, small, medium, large
# ==============================
WHISPER_MODEL=small
PYTHON_PATH=python3

# ==============================
# FFMPEG PATHS (Windows par agar PATH issue ho to)
# "where ffmpeg" aur "where ffprobe" chalao terminal me,
# jo path mile wo yahan daalo (double backslash use karo).
# Example: FFMPEG_PATH=C:\\ffmpeg\\bin\\ffmpeg.exe
# Mac/Linux par ye khali chhod sakte ho.
# ==============================
FFMPEG_PATH=
FFPROBE_PATH=

# ==============================
# FOLDERS
# ==============================
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
